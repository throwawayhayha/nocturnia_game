title: Oriana has fulfilled the request.
subtitle: The sabotaging operation has been successful.
view-if: ori_timer = 5 and day >= 3 and ori_act_done = 0
new-page: true
tags: events
on-arrival: ori_act_done = 1; prosecution_strength -= 2; prosecution_strength -= 1 if (prosecution_strength - defense_strength > 2); prosecution_strength -= 1 if (prosecution_strength - defense_strength > 4); knowledge_politics += 3; relation_nobility -= 3; relation_darlyne += 2; darlyne_mood += 2;

